{
  "name": "dep-lens",
  "displayName": "DepLens — Monorepo Dependency Manager",
  "description": "Inline version upgrades, pnpm catalog support, and cross-package version-drift detection for monorepos",
  "version": "0.1.0",
  "publisher": "andreymay",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreyMay/dep-lens"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "pnpm",
    "catalog",
    "dependencies",
    "upgrade",
    "monorepo",
    "version",
    "npm"
  ],
  "activationEvents": [
    "workspaceContains:pnpm-workspace.yaml",
    "workspaceContains:package.json",
    "onLanguage:yaml",
    "onLanguage:json",
    "onLanguage:jsonc"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "depLens.updateAll",
        "title": "DepLens: Update All Dependencies"
      },
      {
        "command": "depLens.toggle",
        "title": "DepLens: Toggle Decorations"
      },
      {
        "command": "depLens.refresh",
        "title": "DepLens: Refresh Version Data"
      }
    ],
    "configuration": {
      "title": "DepLens",
      "properties": {
        "depLens.showDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show version upgrade decorations in package.json and pnpm-workspace.yaml"
        },
        "depLens.showUsageCount": {
          "type": "boolean",
          "default": true,
          "description": "Show how many workspace packages use each catalog dependency (in pnpm-workspace.yaml)"
        },
        "depLens.showPrerelease": {
          "type": "boolean",
          "default": false,
          "description": "Show latest beta/canary/prerelease version alongside stable upgrades"
        },
        "depLens.hideOnCursorLine": {
          "type": "boolean",
          "default": false,
          "description": "Hide inline decorations when the cursor is on that line"
        },
        "depLens.excludePaths": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.next/**",
            "**/.open-next/**",
            "**/.turbo/**",
            "**/.vercel/**",
            "**/.sst/**",
            "**/.sst*/**",
            "**/dist/**",
            "**/build/**",
            "**/out/**",
            "**/.cache/**",
            "**/coverage/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns for paths to exclude when scanning package.json files"
        },
        "depLens.allowedMismatches": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Package names whose version mismatches should not be flagged. Use the code action **\"Allow version mismatch\"** to add entries, or edit manually."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "semver": "^7.6.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/semver": "^7.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.26.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
